		},
		"9333858b-1d78-4d76-9e2b-1f3d96759c44": {
			"path": "9333858b-1d78-4d76-9e2b-1f3d96759c44",
			"cellName": "Docker Deployment Flow: Application Served - Dockerfile:L17",
			"cellId": "9333858b-1d78-4d76-9e2b-1f3d96759c44",
			"visible": true,
			"parentCellId": "632fb9b1-181c-4f57-978e-3ac06a17a20c"
		},
		"Dockerfile-simstep-374ab1f5-640e-4b12-84a2-164f3accca29": {
			"path": "Dockerfile-simstep-374ab1f5-640e-4b12-84a2-164f3accca29",
			"fileName": "Dockerfile",
			"wiki": "Nginx serves the static `index.html` and other assets from `/usr/share/nginx/html`. The application is now accessible to the user by navigating to `http://localhost:8080` in their web browser.",
