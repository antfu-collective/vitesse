		"src/main.ts-simstep-84f558b7-086f-4273-9286-04a737ba20fd": {
			"path": "src/main.ts-simstep-84f558b7-086f-4273-9286-04a737ba20fd",
			"fileName": "main.ts",
			"wiki": "The UnoCSS Vite plugin creates a virtual module named `uno.css` that contains all the on-demand CSS rules. This virtual module can be imported like a regular CSS file in the application's source code.",
