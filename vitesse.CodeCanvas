					"outputDataExample": "{\n  \"generatedCss\": \".icon-btn{display:inline-block;cursor:pointer;-webkit-user-select:none;user-select:none;opacity:.75;transition-duration:.2s;transition-timing-function:cubic-bezier(.4,0,.2,1);transition-property:all}.icon-btn:hover{opacity:1;--un-text-opacity:1;color:rgba(15,118,110,var(--un-text-opacity))}.i-carbon-campsite{display:inline-block;width:1.2em;height:1.2em;background-color:currentColor;mask:url('data:image/svg+xml,%3csvg ...') no-repeat;mask-size:100% 100%;-webkit-mask:url('data:image/svg+xml,%3csvg ...') no-repeat;-webkit-mask-size:100% 100%}\"\n}"
				},
