					"outputDataExample": "{\n  \"foundClasses\": [\n    \"flex\",\n    \"gap-4\",\n    \"mt-6\",\n    \"justify-center\",\n    \"text-xl\",\n    \"icon-btn\",\n    \"i-carbon-campsite\",\n    \"i-carbon-sun\",\n    \"dark:carbon-moon\"\n  ]\n}"
