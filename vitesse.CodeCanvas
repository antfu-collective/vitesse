				{
					"simStepId": "99423d1e-00f3-4eb9-aa2f-1d3b23d00aa7",
					"diagramNodeId": "dfd43c23-5f93-4643-b9df-29f9a7643014",
					"simStepLabel": "Unit & Component Test Flow: Trigger Test Command",
					"simStepDescription": "A developer or a CI pipeline executes the test command, which invokes the Vitest test runner.",
					"isEdge": 1,
					"sourceCodeMapping": {
