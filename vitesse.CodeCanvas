		"Pre-configured Testing Suite (Unit & E2E)": {
			"name": "Pre-configured Testing Suite (Unit & E2E)",
			"simSteps": [
				{
					"simStepId": "c27ec2f9-fc03-4e2f-ac32-28fc5ccb4501",
					"diagramNodeId": "e1ef1acc-40d1-4bf3-bf14-b9d800a57e7d",
					"simStepLabel": "Unit & Component Test Flow: Configure Vitest",
					"simStepDescription": "The testing process starts with the configuration for Vitest, the testing framework. This file specifies the test environment (jsdom for simulating a browser), and the file patterns for test discovery.",
					"isEdge": 0,
					"sourceCodeMapping": {
						"filePath": "vite.config.ts",
						"startLine": "145",
						"endLine": "149",
						"relevantVariables": [
