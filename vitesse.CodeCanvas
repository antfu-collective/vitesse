	"simulations": {
		"Automatic File-System Based Routing": {
			"name": "Automatic File-System Based Routing",
			"simSteps": [
				{
					"simStepId": "4bd86f98-460b-4466-bad0-bff4580ca40d",
					"diagramNodeId": "7abe4a0b-d30f-4330-bf0b-1ecc7180c52a",
					"simStepLabel": "Config: Vite Plugin Configuration",
					"simStepDescription": "The build process starts by reading `vite.config.ts`. This file registers several Vite plugins, but two are critical for routing: `unplugin-vue-router` for file-system based route generation and `vite-plugin-vue-layouts` for handling page layouts.",
					"isEdge": 0,
					"sourceCodeMapping": {
						"filePath": "vite.config.ts",
						"startLine": "28",
						"endLine": "45",
						"relevantVariables": [
							"VueRouter",
							"Layouts"
						]
					},
					"inputDataExample": "null",
					"outputDataExample": "{\n  \"plugins\": [\n    \"VueRouter({...})\",\n    \"Layouts()\",\n    \"...other plugins\"\n  ]\n}"
				},
				{
					"simStepId": "11fcf6ac-4d14-40da-af48-c8af9934a130",
					"diagramNodeId": "a18d481d-dcac-4eef-a387-b8d2a901e7e9",
					"simStepLabel": "Config: Vite Initializing Plugins",
					"simStepDescription": "Vite initializes the configured plugins. At this stage, the file system scanning for pages and layouts has not yet occurred.",
					"isEdge": 1,
					"sourceCodeMapping": {
						"filePath": "vite.config.ts",
						"startLine": "29",
						"endLine": "44",
						"relevantVariables": [
							"VueRouter({...})",
							"Layouts()"
						]
					},
					"inputDataExample": "{\n  \"VueRouterOptions\": {\n    \"extensions\": [\".vue\", \".md\"],\n    \"dts\": \"src/typed-router.d.ts\"\n  },\n  \"LayoutsOptions\": {}\n}",
					"outputDataExample": "{\n  \"VueRouterOptions\": {\n    \"extensions\": [\".vue\", \".md\"],\n    \"dts\": \"src/typed-router.d.ts\"\n  },\n  \"LayoutsOptions\": {}\n}"
				},
				{
					"simStepId": "f31e3e98-4697-430e-a73b-147fc668ad55",
					"diagramNodeId": "e93101c3-4fb8-4058-87ce-6ad522905596",
					"simStepLabel": "Build-Time: `unplugin-vue-router` Scans Pages Directory",
					"simStepDescription": "During the Vite build process, `unplugin-vue-router` scans the `src/pages` directory. It interprets the filenames to generate an array of route records. For example, `index.vue` becomes the `/` path, and `hi/[name].vue` becomes a dynamic route `/hi/:name`.",
					"isEdge": 0,
					"sourceCodeMapping": {
						"filePath": "vite.config.ts",
						"startLine": "30",
						"endLine": "33",
						"relevantVariables": [
							"VueRouter"
						]
					},
					"inputDataExample": "[\n  \"src/pages/index.vue\",\n  \"src/pages/about.md\",\n  \"src/pages/hi/[name].vue\",\n  \"src/pages/[...all].vue\"\n]",
					"outputDataExample": "[\n  {\n    \"path\": \"/\",\n    \"name\": \"/\",\n    \"component\": \"/src/pages/index.vue\"\n  },\n  {\n    \"path\": \"/about\",\n    \"name\": \"/about\",\n    \"component\": \"/src/pages/about.md\"\n  },\n  {\n    \"path\": \"/hi/:name\",\n    \"name\": \"/hi/[name]\",\n    \"component\": \"/src/pages/hi/[name].vue\"\n  },\n  {\n    \"path\": \"/:all(.*)\",\n    \"name\": \"/[...all]\",\n    \"component\": \"/src/pages/[...all].vue\"\n  }\n]"
				},
				{
					"simStepId": "eb8209a0-916f-4032-9b00-3d1ab7510e20",
					"diagramNodeId": "e6162506-dfbb-4094-98f2-8cf28ca90283",
					"simStepLabel": "Data Transmission: Routes Available as a Virtual Module",
					"simStepDescription": "The generated route array is made available to the application via a virtual module, `vue-router/auto-routes`. Additionally, the plugin generates a TypeScript declaration file at `src/typed-router.d.ts` to provide type-safety for these routes.",
					"isEdge": 1,
					"sourceCodeMapping": {
						"filePath": "src/main.ts",
						"startLine": "5",
						"endLine": "5",
						"relevantVariables": [
							"routes from 'vue-router/auto-routes'"
						]
					},
					"inputDataExample": "[\n  {\n    \"path\": \"/\",\n    \"name\": \"/\",\n    \"component\": \"/src/pages/index.vue\"\n  },\n  {\n    \"path\": \"/hi/:name\",\n    \"name\": \"/hi/[name]\",\n    \"component\": \"/src/pages/hi/[name].vue\"\n  }\n]",
					"outputDataExample": "[\n  {\n    \"path\": \"/\",\n    \"name\": \"/\",\n    \"component\": \"/src/pages/index.vue\"\n  },\n  {\n    \"path\": \"/hi/:name\",\n    \"name\": \"/hi/[name]\",\n    \"component\": \"/src/pages/hi/[name].vue\"\n  }\n]"
				},
				{
					"simStepId": "e7d871c0-e84f-47cf-8a91-2dc79161be56",
					"diagramNodeId": "47ef3803-8a4f-4b9a-9d46-6847727699c7",
					"simStepLabel": "Build-Time: `vite-plugin-vue-layouts` Processes Layouts",
					"simStepDescription": "The `vite-plugin-vue-layouts` plugin scans page components (e.g., `src/pages/index.vue`) for a `<route>` block. If a layout is specified in the metadata (e.g., `layout: home`), it maps that route to the corresponding component in the `src/layouts` directory (e.g., `home.vue`). If no layout is specified, it defaults to `default.vue`.",
					"isEdge": 0,
					"sourceCodeMapping": {
						"filePath": "src/pages/index.vue",
						"startLine": "56",
						"endLine": "59",
						"relevantVariables": [
							"<route>"
						]
					},
					"inputDataExample": "{\n  \"page\": \"src/pages/index.vue\",\n  \"routeBlock\": \"<route lang='yaml'>meta: { layout: home }</route>\",\n  \"layoutsDir\": \"src/layouts\"\n}",
					"outputDataExample": "{\n  \"routePath\": \"/\",\n  \"layout\": \"home\"\n}"
				},
				{
					"simStepId": "170d6a47-87d3-4a1b-baa6-031517e8322b",
					"diagramNodeId": "9b6dfe5d-bf3c-4da3-8b20-e15431c4a0ec",
					"simStepLabel": "Data Transmission: Layout Wrapper Function Exposed",
					"simStepDescription": "The layout plugin creates another virtual module, `virtual:generated-layouts`, which exports a `setupLayouts` function. This function is designed to take the array of routes from `unplugin-vue-router` and wrap them with the appropriate layout components, creating a nested route structure.",
					"isEdge": 1,
					"sourceCodeMapping": {
						"filePath": "src/main.ts",
						"startLine": "3",
						"endLine": "3",
						"relevantVariables": [
							"setupLayouts from 'virtual:generated-layouts'"
						]
					},
					"inputDataExample": "{\n  \"functionName\": \"setupLayouts\",\n  \"description\": \"A function that wraps route components with layout components.\"\n}",
					"outputDataExample": "{\n  \"functionName\": \"setupLayouts\",\n  \"description\": \"A function that wraps route components with layout components.\"\n}"
				},
				{
					"simStepId": "46252056-9093-4504-bde2-bef9770ecc03",
					"diagramNodeId": "cde61b97-04f4-415d-a2f4-44885ee28458",
					"simStepLabel": "Runtime: Application Initialization",
					"simStepDescription": "At runtime, the application's entry point `src/main.ts` executes. It imports the `routes` from `vue-router/auto-routes` and the `setupLayouts` function from `virtual:generated-layouts`. These are then passed to `ViteSSG` to configure the Vue app and router.",
					"isEdge": 0,
					"sourceCodeMapping": {
						"filePath": "src/main.ts",
						"startLine": "13",
						"endLine": "18",
						"relevantVariables": [
							"createApp",
							"ViteSSG",
							"routes",
							"setupLayouts"
						]
					},
					"inputDataExample": "null",
					"outputDataExample": "{\n  \"routes\": \"[...routes from virtual module]\",\n  \"setupLayouts\": \"<function from virtual module>\"\n}"
				},
				{
					"simStepId": "cc8058bf-7747-4604-99bd-fb7ebb17cfd4",
					"diagramNodeId": "f70b5ff4-fed2-4060-aa2d-3c47a90cd12d",
					"simStepLabel": "Data Transformation: Combining Routes and Layouts",
					"simStepDescription": "The raw `routes` array is passed to the `setupLayouts` function, which processes the array and wraps each page component with its designated layout component.",
					"isEdge": 1,
					"sourceCodeMapping": {
						"filePath": "src/main.ts",
						"startLine": "16",
						"endLine": "16",
						"relevantVariables": [
							"setupLayouts(routes)"
						]
					},
					"inputDataExample": "[\n  {\n    \"path\": \"/\",\n    \"component\": \"/src/pages/index.vue\",\n    \"meta\": { \"layout\": \"home\" }\n  },\n  {\n    \"path\": \"/about\",\n    \"component\": \"/src/pages/about.md\"\n  }\n]",
					"outputDataExample": "[\n  {\n    \"path\": \"/\",\n    \"component\": \"/src/pages/index.vue\",\n    \"meta\": { \"layout\": \"home\" }\n  },\n  {\n    \"path\": \"/about\",\n    \"component\": \"/src/pages/about.md\"\n  }\n]"
				},
				{
					"simStepId": "0fb04f06-d341-4172-9ee0-620fb58f895c",
					"diagramNodeId": "b3003e9a-1955-4623-b22a-a98e43223dbe",
					"simStepLabel": "Runtime: Vue Router Instantiation",
					"simStepDescription": "The `setupLayouts` function returns a new, nested route configuration. `ViteSSG` uses this final configuration to create the Vue Router instance. The routes are now structured such that the layout component is the parent route and the page component is its child, rendered in the layout's `<RouterView />`.",
					"isEdge": 0,
					"sourceCodeMapping": {
						"filePath": "src/main.ts",
						"startLine": "13",
						"endLine": "25",
						"relevantVariables": [
							"ViteSSG",
							"routes"
						]
					},
					"inputDataExample": "[\n  {\n    \"path\": \"/\",\n    \"component\": \"<HomeLayout>\",\n    \"children\": [\n      { \"path\": \"\", \"component\": \"<IndexPage>\" }\n    ]\n  },\n  {\n    \"path\": \"/about\",\n    \"component\": \"<DefaultLayout>\",\n    \"children\": [\n      { \"path\": \"\", \"component\": \"<AboutPage>\" }\n    ]\n  }\n]",
					"outputDataExample": "{\n  \"routerInstance\": {\n    \"currentRoute\": \"/\",\n    \"routes\": \"[...final nested routes]\"\n  }\n}"
				},
				{
					"simStepId": "5d7e0ecd-4a31-4d0a-895e-565d6120e8c5",
					"diagramNodeId": "54514223-35f9-4dcb-a7f9-25cbc85e0eef",
					"simStepLabel": "Data Transmission: Router Instance Provided to App",
					"simStepDescription": "The newly created router instance is installed into the root Vue `App` instance, making routing capabilities available throughout the entire application.",
					"isEdge": 1,
					"sourceCodeMapping": {
						"filePath": "src/main.ts",
						"startLine": "13",
						"endLine": "14",
						"relevantVariables": [
							"ViteSSG",
							"App"
						]
					},
					"inputDataExample": "{\n  \"routerInstance\": \"[VueRouter instance]\"\n}",
					"outputDataExample": "{\n  \"routerInstance\": \"[VueRouter instance]\"\n}"
				},
				{
					"simStepId": "ab6516c1-e2c3-46cd-be10-eabe2474084a",
					"diagramNodeId": "8d256e62-af23-476e-ad24-6b33ee5ff205",
					"simStepLabel": "Runtime: Render Root Component",
					"simStepDescription": "The main `App.vue` component is mounted. Its template contains a single `<RouterView />` component, which serves as the entry point for rendering the currently active route.",
					"isEdge": 0,
					"sourceCodeMapping": {
						"filePath": "src/App.vue",
						"startLine": "27",
						"endLine": "29",
						"relevantVariables": [
							"RouterView"
						]
					},
					"inputDataExample": "null",
					"outputDataExample": "null"
				},
				{
					"simStepId": "8712fafb-7860-44b5-8d45-64f7ac5ec07e",
					"diagramNodeId": "08e29138-acab-4227-92b3-2924b78c1c9b",
					"simStepLabel": "Navigation: User Navigates to a Dynamic Route",
					"simStepDescription": "When the user navigates to a path like `/hi/Vitesse`, Vue Router matches this against the generated route `/hi/:name`.",
					"isEdge": 1,
					"sourceCodeMapping": {
						"filePath": "src/pages/index.vue",
						"startLine": "9",
						"endLine": "12",
						"relevantVariables": [
							"router.push"
						]
					},
					"inputDataExample": "{\n  \"action\": \"router.push\",\n  \"path\": \"/hi/Vitesse\"\n}",
					"outputDataExample": "{\n  \"action\": \"router.push\",\n  \"path\": \"/hi/Vitesse\"\n}"
				},
				{
					"simStepId": "b06078de-2cfe-4a4f-89a9-671cb1a8b466",
					"diagramNodeId": "c7ea038d-9f78-4610-bff8-1594dc7b9649",
					"simStepLabel": "Runtime: Render Dynamic Route Component",
					"simStepDescription": "Vue Router renders the matched component. Since no layout is specified in `src/pages/hi/[name].vue`, it uses `src/layouts/default.vue`. The `default.vue` layout is rendered, and inside its `<RouterView />`, the `[name].vue` page component is rendered. The component can then access the route parameters (e.g., `name: 'Vitesse'`) using `useRoute()`.",
					"isEdge": 0,
					"sourceCodeMapping": {
						"filePath": "src/pages/hi/[name].vue",
						"startLine": "1",
						"endLine": "50",
						"relevantVariables": [
							"useRoute",
							"route.params.name",
							"router"
						]
					},
					"inputDataExample": "{\n  \"matchedRoute\": {\n    \"path\": \"/hi/:name\",\n    \"params\": { \"name\": \"Vitesse\" }\n  }\n}",
					"outputDataExample": "{\n  \"renderedLayout\": \"default.vue\",\n  \"renderedPage\": \"[name].vue\",\n  \"routeParams\": { \"name\": \"Vitesse\" }\n}"
				}
			],
			"description": "<ul><li>This starter template provides an intuitive file-system based routing system</li><li>- Developers can create new pages and routes simply by adding <code></li><li>vue</code> or <code></li><li>md</code> files to the <code>src/pages</code> directory</li><li>- It supports dynamic routes using bracket notation (e</li><li>g</li><li>, <code>src/pages/hi/name</li><li>vue</code>)</li><li>- A layout system is integrated, allowing pages to specify a layout (from <code>src/layouts</code>) in a <code><route></code> block, as seen in <code>src/pages/index</li><li>vue</code></li></ul>",
