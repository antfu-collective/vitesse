			]
		},
		"bf811c57-170e-4bc1-8d80-ba6767bbdbcc": {
			"path": "bf811c57-170e-4bc1-8d80-ba6767bbdbcc",
			"cellName": "Virtual CSS Module Creation - main.ts:L10",
			"cellId": "bf811c57-170e-4bc1-8d80-ba6767bbdbcc",
			"visible": true,
			"parentCellId": "b33cf786-b499-4506-b9d2-0f60ca79bdc6"
