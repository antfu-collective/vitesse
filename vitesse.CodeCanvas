		"7abe4a0b-d30f-4330-bf0b-1ecc7180c52a": {
			"path": "7abe4a0b-d30f-4330-bf0b-1ecc7180c52a",
			"cellName": "Config: Vite Plugin Configuration - vite.config.ts:L28-45",
			"cellId": "7abe4a0b-d30f-4330-bf0b-1ecc7180c52a",
			"visible": true,
			"parentCellId": "ccc305be-cda4-4b7e-a555-b3a8456bb06e"
		},
		"vite.config.ts-simstep-4bd86f98-460b-4466-bad0-bff4580ca40d": {
			"path": "vite.config.ts-simstep-4bd86f98-460b-4466-bad0-bff4580ca40d",
			"fileName": "vite.config.ts",
			"wiki": "The build process starts by reading `vite.config.ts`. This file registers several Vite plugins, but two are critical for routing: `unplugin-vue-router` for file-system based route generation and `vite-plugin-vue-layouts` for handling page layouts.",
			"cellName": "Config: Vite Plugin Configuration - vite.config.ts:L28-45",
			"cellId": "7abe4a0b-d30f-4330-bf0b-1ecc7180c52a",
			"visible": true,
			"startLine": 28,
			"endLine": 45,
			"parentCellId": "ccc305be-cda4-4b7e-a555-b3a8456bb06e",
			"parentPath": "vite.config.ts",
			"simSteps": [
				{
					"simulationKey": "Automatic File-System Based Routing",
					"simStepId": "4bd86f98-460b-4466-bad0-bff4580ca40d"
				}
			]
		},
		"e93101c3-4fb8-4058-87ce-6ad522905596": {
			"path": "e93101c3-4fb8-4058-87ce-6ad522905596",
			"cellName": "Build-Time: `unplugin-vue-router` Scans Pages Directory - vite.config.ts:L30-33",
			"cellId": "e93101c3-4fb8-4058-87ce-6ad522905596",
			"visible": true,
			"parentCellId": "ccc305be-cda4-4b7e-a555-b3a8456bb06e"
		},
		"vite.config.ts-simstep-f31e3e98-4697-430e-a73b-147fc668ad55": {
			"path": "vite.config.ts-simstep-f31e3e98-4697-430e-a73b-147fc668ad55",
			"fileName": "vite.config.ts",
			"wiki": "During the Vite build process, `unplugin-vue-router` scans the `src/pages` directory. It interprets the filenames to generate an array of route records. For example, `index.vue` becomes the `/` path, and `hi/[name].vue` becomes a dynamic route `/hi/:name`.",
			"cellName": "Build-Time: `unplugin-vue-router` Scans Pages Directory - vite.config.ts:L30-33",
			"cellId": "e93101c3-4fb8-4058-87ce-6ad522905596",
			"visible": true,
			"startLine": 30,
			"endLine": 33,
			"parentCellId": "ccc305be-cda4-4b7e-a555-b3a8456bb06e",
			"parentPath": "vite.config.ts",
			"simSteps": [
				{
					"simulationKey": "Automatic File-System Based Routing",
					"simStepId": "f31e3e98-4697-430e-a73b-147fc668ad55"
				}
			]
		},
		"47ef3803-8a4f-4b9a-9d46-6847727699c7": {
			"path": "47ef3803-8a4f-4b9a-9d46-6847727699c7",
			"cellName": "Build-Time: `vite-plugin-vue-layouts` Processes Layouts - index.vue:L56-59",
			"cellId": "47ef3803-8a4f-4b9a-9d46-6847727699c7",
			"visible": true,
			"parentCellId": "d352f96a-4744-422b-bb32-ef5bb297550b"
		},
		"src/pages/index.vue-simstep-e7d871c0-e84f-47cf-8a91-2dc79161be56": {
			"path": "src/pages/index.vue-simstep-e7d871c0-e84f-47cf-8a91-2dc79161be56",
			"fileName": "index.vue",
			"wiki": "The `vite-plugin-vue-layouts` plugin scans page components (e.g., `src/pages/index.vue`) for a `<route>` block. If a layout is specified in the metadata (e.g., `layout: home`), it maps that route to the corresponding component in the `src/layouts` directory (e.g., `home.vue`). If no layout is specified, it defaults to `default.vue`.",
			"cellName": "Build-Time: `vite-plugin-vue-layouts` Processes Layouts - index.vue:L56-59",
			"cellId": "47ef3803-8a4f-4b9a-9d46-6847727699c7",
			"visible": true,
			"startLine": 56,
			"endLine": 59,
			"parentCellId": "d352f96a-4744-422b-bb32-ef5bb297550b",
			"parentPath": "src/pages/index.vue",
			"simSteps": [
				{
					"simulationKey": "Automatic File-System Based Routing",
					"simStepId": "e7d871c0-e84f-47cf-8a91-2dc79161be56"
				}
			]
		},
		"cde61b97-04f4-415d-a2f4-44885ee28458": {
			"path": "cde61b97-04f4-415d-a2f4-44885ee28458",
			"cellName": "Runtime: Application Initialization - main.ts:L13-18",
			"cellId": "cde61b97-04f4-415d-a2f4-44885ee28458",
			"visible": true,
			"parentCellId": "b33cf786-b499-4506-b9d2-0f60ca79bdc6"
		},
		"src/main.ts-simstep-46252056-9093-4504-bde2-bef9770ecc03": {
			"path": "src/main.ts-simstep-46252056-9093-4504-bde2-bef9770ecc03",
			"fileName": "main.ts",
			"wiki": "At runtime, the application's entry point `src/main.ts` executes. It imports the `routes` from `vue-router/auto-routes` and the `setupLayouts` function from `virtual:generated-layouts`. These are then passed to `ViteSSG` to configure the Vue app and router.",
			"cellName": "Runtime: Application Initialization - main.ts:L13-18",
			"cellId": "cde61b97-04f4-415d-a2f4-44885ee28458",
			"visible": true,
			"startLine": 13,
			"endLine": 18,
			"parentCellId": "b33cf786-b499-4506-b9d2-0f60ca79bdc6",
			"parentPath": "src/main.ts",
			"simSteps": [
				{
					"simulationKey": "Automatic File-System Based Routing",
					"simStepId": "46252056-9093-4504-bde2-bef9770ecc03"
				}
			]
		},
		"b3003e9a-1955-4623-b22a-a98e43223dbe": {
			"path": "b3003e9a-1955-4623-b22a-a98e43223dbe",
			"cellName": "Runtime: Vue Router Instantiation - main.ts:L13-25",
			"cellId": "b3003e9a-1955-4623-b22a-a98e43223dbe",
			"visible": true,
			"parentCellId": "b33cf786-b499-4506-b9d2-0f60ca79bdc6"
		},
		"src/main.ts-simstep-0fb04f06-d341-4172-9ee0-620fb58f895c": {
			"path": "src/main.ts-simstep-0fb04f06-d341-4172-9ee0-620fb58f895c",
			"fileName": "main.ts",
			"wiki": "The `setupLayouts` function returns a new, nested route configuration. `ViteSSG` uses this final configuration to create the Vue Router instance. The routes are now structured such that the layout component is the parent route and the page component is its child, rendered in the layout's `<RouterView />`.",
			"cellName": "Runtime: Vue Router Instantiation - main.ts:L13-25",
			"cellId": "b3003e9a-1955-4623-b22a-a98e43223dbe",
			"visible": true,
			"startLine": 13,
			"endLine": 25,
			"parentCellId": "b33cf786-b499-4506-b9d2-0f60ca79bdc6",
			"parentPath": "src/main.ts",
			"simSteps": [
				{
					"simulationKey": "Automatic File-System Based Routing",
					"simStepId": "0fb04f06-d341-4172-9ee0-620fb58f895c"
				}
			]
		},
		"8d256e62-af23-476e-ad24-6b33ee5ff205": {
			"path": "8d256e62-af23-476e-ad24-6b33ee5ff205",
			"cellName": "Runtime: Render Root Component - App.vue:L27-29",
			"cellId": "8d256e62-af23-476e-ad24-6b33ee5ff205",
			"visible": true,
			"parentCellId": "12e4062f-1e07-4c19-ac02-af2d7433b2b7"
		},
		"src/App.vue-simstep-ab6516c1-e2c3-46cd-be10-eabe2474084a": {
			"path": "src/App.vue-simstep-ab6516c1-e2c3-46cd-be10-eabe2474084a",
			"fileName": "App.vue",
			"wiki": "The main `App.vue` component is mounted. Its template contains a single `<RouterView />` component, which serves as the entry point for rendering the currently active route.",
			"cellName": "Runtime: Render Root Component - App.vue:L27-29",
			"cellId": "8d256e62-af23-476e-ad24-6b33ee5ff205",
			"visible": true,
			"startLine": 27,
			"endLine": 29,
			"parentCellId": "12e4062f-1e07-4c19-ac02-af2d7433b2b7",
			"parentPath": "src/App.vue",
			"simSteps": [
				{
					"simulationKey": "Automatic File-System Based Routing",
					"simStepId": "ab6516c1-e2c3-46cd-be10-eabe2474084a"
				}
			]
		},
		"c7ea038d-9f78-4610-bff8-1594dc7b9649": {
			"path": "c7ea038d-9f78-4610-bff8-1594dc7b9649",
			"cellName": "Runtime: Render Dynamic Route Component - [name].vue:L1-50",
			"cellId": "c7ea038d-9f78-4610-bff8-1594dc7b9649",
			"visible": true,
			"parentCellId": "2e718514-9d3b-4e54-96ac-9e1167c09b66"
		},
		"src/pages/hi/[name].vue-simstep-b06078de-2cfe-4a4f-89a9-671cb1a8b466": {
			"path": "src/pages/hi/[name].vue-simstep-b06078de-2cfe-4a4f-89a9-671cb1a8b466",
			"fileName": "[name].vue",
			"wiki": "Vue Router renders the matched component. Since no layout is specified in `src/pages/hi/[name].vue`, it uses `src/layouts/default.vue`. The `default.vue` layout is rendered, and inside its `<RouterView />`, the `[name].vue` page component is rendered. The component can then access the route parameters (e.g., `name: 'Vitesse'`) using `useRoute()`.",
			"cellName": "Runtime: Render Dynamic Route Component - [name].vue:L1-50",
			"cellId": "c7ea038d-9f78-4610-bff8-1594dc7b9649",
			"visible": true,
			"startLine": 1,
			"endLine": 50,
			"parentCellId": "2e718514-9d3b-4e54-96ac-9e1167c09b66",
