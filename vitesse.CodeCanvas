		},
		"988f6c38-eed4-4efc-9e15-39b8f6e428bd": {
			"path": "988f6c38-eed4-4efc-9e15-39b8f6e428bd",
			"cellName": "Netlify Deployment Flow: Configuration - netlify.toml:L1-11",
			"cellId": "988f6c38-eed4-4efc-9e15-39b8f6e428bd",
			"visible": true,
			"parentCellId": "2bd3ee6d-6e96-4ba3-9fef-030bc41bb2b0"
		},
		"netlify.toml-simstep-60d8487e-1766-4718-a981-9e212a56ad67": {
			"path": "netlify.toml-simstep-60d8487e-1766-4718-a981-9e212a56ad67",
			"fileName": "netlify.toml",
			"wiki": "The deployment process for Netlify is defined in the `netlify.toml` file. This configuration specifies the build command to run (`pnpm run build`), the directory to publish (`dist`), and the Node.js version to use. It also defines redirects for single-page application (SPA) routing.",
			"cellName": "Netlify Deployment Flow: Configuration - netlify.toml:L1-11",
			"cellId": "988f6c38-eed4-4efc-9e15-39b8f6e428bd",
			"visible": true,
			"startLine": 1,
			"endLine": 11,
			"parentCellId": "2bd3ee6d-6e96-4ba3-9fef-030bc41bb2b0",
			"parentPath": "netlify.toml",
			"simSteps": [
				{
					"simulationKey": "Zero-Configuration Deployment",
					"simStepId": "60d8487e-1766-4718-a981-9e212a56ad67"
				}
			]
		},
		"5c8d6abf-5de5-4bdb-b7ab-efd9dce0007d": {
			"path": "5c8d6abf-5de5-4bdb-b7ab-efd9dce0007d",
			"cellName": "Netlify Deployment Flow: Execute Build Command - netlify.toml:L3",
			"cellId": "5c8d6abf-5de5-4bdb-b7ab-efd9dce0007d",
			"visible": true,
			"parentCellId": "2bd3ee6d-6e96-4ba3-9fef-030bc41bb2b0"
		},
		"netlify.toml-simstep-a9dce1a0-6571-42c5-8caa-0b5e934c836a": {
			"path": "netlify.toml-simstep-a9dce1a0-6571-42c5-8caa-0b5e934c836a",
			"fileName": "netlify.toml",
			"wiki": "Netlify's build environment executes the `pnpm run build` command as specified in the configuration. This command transpiles the Vue.js application, bundles assets, and prepares static files for production.",
			"cellName": "Netlify Deployment Flow: Execute Build Command - netlify.toml:L3",
			"cellId": "5c8d6abf-5de5-4bdb-b7ab-efd9dce0007d",
			"visible": true,
			"startLine": 3,
			"endLine": 3,
			"parentCellId": "2bd3ee6d-6e96-4ba3-9fef-030bc41bb2b0",
			"parentPath": "netlify.toml",
			"simSteps": [
				{
					"simulationKey": "Zero-Configuration Deployment",
					"simStepId": "a9dce1a0-6571-42c5-8caa-0b5e934c836a"
				}
			]
		},
		"041776e2-5dfd-44c1-a02c-fa708938a93e": {
			"path": "041776e2-5dfd-44c1-a02c-fa708938a93e",
			"cellName": "Netlify Deployment Flow: Deploy to CDN - netlify.toml:L2-11",
			"cellId": "041776e2-5dfd-44c1-a02c-fa708938a93e",
			"visible": true,
			"parentCellId": "2bd3ee6d-6e96-4ba3-9fef-030bc41bb2b0"
		},
		"netlify.toml-simstep-ba9be284-c766-4244-8258-12f7e2fc5149": {
			"path": "netlify.toml-simstep-ba9be284-c766-4244-8258-12f7e2fc5149",
			"fileName": "netlify.toml",
			"wiki": "Netlify takes the contents of the `dist` directory and deploys them to its global Content Delivery Network (CDN). It also applies the specified SPA redirect rule, ensuring that all paths are routed to `index.html`.",
			"cellName": "Netlify Deployment Flow: Deploy to CDN - netlify.toml:L2-11",
			"cellId": "041776e2-5dfd-44c1-a02c-fa708938a93e",
			"visible": true,
			"startLine": 2,
			"endLine": 11,
			"parentCellId": "2bd3ee6d-6e96-4ba3-9fef-030bc41bb2b0",
			"parentPath": "netlify.toml",
			"simSteps": [
				{
					"simulationKey": "Zero-Configuration Deployment",
					"simStepId": "ba9be284-c766-4244-8258-12f7e2fc5149"
				}
			]
		},
		"6d75c0ed-926e-4828-bfb5-a11edd4c609f": {
			"path": "6d75c0ed-926e-4828-bfb5-a11edd4c609f",
			"cellName": "Docker Deployment Flow: User Initiates Build - README.md:L203",
			"cellId": "6d75c0ed-926e-4828-bfb5-a11edd4c609f",
			"visible": true,
			"parentCellId": "5e1ebbc2-3044-469b-b589-a150bc65aba0"
		},
		"README.md-simstep-1d3f3a7b-96ed-4b50-b8d7-8a69685d7716": {
			"path": "README.md-simstep-1d3f3a7b-96ed-4b50-b8d7-8a69685d7716",
			"fileName": "README.md",
			"wiki": "A user starts the Docker deployment process by running the `docker buildx build` command. This command instructs Docker to build an image using the `Dockerfile` in the current directory and tag it as `vitesse:latest`.",
			"cellName": "Docker Deployment Flow: User Initiates Build - README.md:L203",
			"cellId": "6d75c0ed-926e-4828-bfb5-a11edd4c609f",
			"visible": true,
			"startLine": 203,
			"endLine": 203,
			"parentCellId": "5e1ebbc2-3044-469b-b589-a150bc65aba0",
			"parentPath": "README.md",
			"simSteps": [
				{
					"simulationKey": "Zero-Configuration Deployment",
					"simStepId": "1d3f3a7b-96ed-4b50-b8d7-8a69685d7716"
				}
			]
		},
		"0806704b-3c08-4139-97e6-a07542c9620b": {
			"path": "0806704b-3c08-4139-97e6-a07542c9620b",
			"cellName": "Docker Deployment Flow: Build Stage 1 (Builder) - Dockerfile:L1-11",
			"cellId": "0806704b-3c08-4139-97e6-a07542c9620b",
			"visible": true,
			"parentCellId": "632fb9b1-181c-4f57-978e-3ac06a17a20c"
		},
		"Dockerfile-simstep-f51536a9-bc93-4620-ae3f-937358bfb44e": {
			"path": "Dockerfile-simstep-f51536a9-bc93-4620-ae3f-937358bfb44e",
			"fileName": "Dockerfile",
			"wiki": "The first stage of the multi-stage `Dockerfile` uses a Node.js base image to build the application. It installs dependencies using `pnpm install` and then runs `pnpm run build` to generate the static production assets.",
			"cellName": "Docker Deployment Flow: Build Stage 1 (Builder) - Dockerfile:L1-11",
			"cellId": "0806704b-3c08-4139-97e6-a07542c9620b",
			"visible": true,
			"startLine": 1,
			"endLine": 11,
			"parentCellId": "632fb9b1-181c-4f57-978e-3ac06a17a20c",
			"parentPath": "Dockerfile",
			"simSteps": [
				{
					"simulationKey": "Zero-Configuration Deployment",
					"simStepId": "f51536a9-bc93-4620-ae3f-937358bfb44e"
				}
			]
		},
		"ab36558f-b549-43e1-b06e-d859a1998e31": {
			"path": "ab36558f-b549-43e1-b06e-d859a1998e31",
			"cellName": "Docker Deployment Flow: Build Stage 2 (Production) - Dockerfile:L13-21",
			"cellId": "ab36558f-b549-43e1-b06e-d859a1998e31",
			"visible": true,
			"parentCellId": "632fb9b1-181c-4f57-978e-3ac06a17a20c"
		},
		"Dockerfile-simstep-d6bdb026-a960-45e9-a3ac-b5d2eda7a85b": {
			"path": "Dockerfile-simstep-d6bdb026-a960-45e9-a3ac-b5d2eda7a85b",
			"fileName": "Dockerfile",
			"wiki": "The second stage uses a lightweight Nginx base image. It copies the build artifacts from the 'builder' stage into the Nginx web server's root directory. The result is a small, optimized production image.",
			"cellName": "Docker Deployment Flow: Build Stage 2 (Production) - Dockerfile:L13-21",
			"cellId": "ab36558f-b549-43e1-b06e-d859a1998e31",
			"visible": true,
			"startLine": 13,
			"endLine": 21,
			"parentCellId": "632fb9b1-181c-4f57-978e-3ac06a17a20c",
			"parentPath": "Dockerfile",
			"simSteps": [
				{
					"simulationKey": "Zero-Configuration Deployment",
					"simStepId": "d6bdb026-a960-45e9-a3ac-b5d2eda7a85b"
				}
			]
		},
		"838e5d7d-8170-4046-a96d-6ec7381b8dde": {
			"path": "838e5d7d-8170-4046-a96d-6ec7381b8dde",
			"cellName": "Docker Deployment Flow: User Runs Container - README.md:L8-200",
			"cellId": "838e5d7d-8170-4046-a96d-6ec7381b8dde",
			"visible": true,
			"parentCellId": "5e1ebbc2-3044-469b-b589-a150bc65aba0"
		},
		"README.md-simstep-0383e8c7-001f-4b1e-a471-91bdb7fc2eca": {
			"path": "README.md-simstep-0383e8c7-001f-4b1e-a471-91bdb7fc2eca",
			"fileName": "README.md",
			"wiki": "The user runs the newly created Docker image as a container using the `docker run` command, mapping port 8080 on the host to port 80 inside the container.",
			"cellName": "Docker Deployment Flow: User Runs Container - README.md:L8-200",
			"cellId": "838e5d7d-8170-4046-a96d-6ec7381b8dde",
			"visible": true,
			"startLine": 8,
			"endLine": 200,
			"parentCellId": "5e1ebbc2-3044-469b-b589-a150bc65aba0",
			"parentPath": "README.md",
			"simSteps": [
				{
					"simulationKey": "Zero-Configuration Deployment",
					"simStepId": "0383e8c7-001f-4b1e-a471-91bdb7fc2eca"
				}
