		"94497f98-069a-40ba-93c5-b3bf12e1f76b": {
			"path": "94497f98-069a-40ba-93c5-b3bf12e1f76b",
			"cellName": "Browser Renders Component with On-Demand Styles - TheFooter.vue:L17-19",
