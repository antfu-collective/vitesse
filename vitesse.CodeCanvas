						]
					},
					"inputDataExample": "{\"command\": \"pnpm run test:unit\"}",
					"outputDataExample": "{\"command\": \"pnpm run test:unit\"}"
				},
				{
					"simStepId": "41c58801-ee2d-4e40-9228-e6ab5a02bf4b",
					"diagramNodeId": "7a79ac4a-3f98-47f2-9c21-e96a2d9f9b59",
					"simStepLabel": "Unit & Component Test Flow: Execute Basic Unit Test",
					"simStepDescription": "Vitest discovers and runs `test/basic.test.ts`. This file contains a simple unit test to ensure the testing setup is functional by asserting a basic arithmetic operation.",
					"isEdge": 0,
					"sourceCodeMapping": {
						"filePath": "test/basic.test.ts",
						"startLine": "3",
						"endLine": "7",
						"relevantVariables": [
							"describe",
							"it",
							"expect"
						]
					},
					"inputDataExample": "{}",
					"outputDataExample": "{\"testResult\": \"pass\", \"assertion\": \"expect(1 + 1).toEqual(2)\"}"
				},
				{
					"simStepId": "be2a15f8-eb63-4e55-99e3-13f51370533b",
					"diagramNodeId": "6eab34df-d784-4f1a-878e-2b974883b05c",
					"simStepLabel": "Unit & Component Test Flow: Load Component Test File",
					"simStepDescription": "After the basic test, Vitest proceeds to the next test file, `test/component.test.ts`, which is designed to test a Vue component.",
					"isEdge": 1,
					"sourceCodeMapping": {
